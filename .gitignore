# =============================================================================
# NexaLink .gitignore
# SEC-01: Prevent accidental exposure of secrets, credentials, and local state
# =============================================================================

# Environment variable files — NEVER commit these
.env
.env.local
.env.production
.env.staging
*.env

# Python build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Client build output
client/dist/
client/.vite/

# Local SQLite database (development fallback)
*.db
*.sqlite
*.sqlite3
nexalink_local.db

# IDE & OS artifacts
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Desktop agent build artifacts
desktop-agent/out/
desktop-agent/dist/

# Electron app data
*.app

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
/tmp/

# Push subscription persistence (runtime state, not code)
.push_subscriptions.json
